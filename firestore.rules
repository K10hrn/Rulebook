rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Entity Validations ---
    function isValidRulebook(data) {
      return data.keys().hasAll(['name', 'size', 'date', 'storagePath']) && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.size is number && data.size > 0 &&
             data.date is number &&
             data.storagePath is string && data.storagePath.size() > 0;
    }

    // --- Collection Rules ---
    match /system/health {
      allow get: if true;
    }

    match /users/{userId} {
      // User profile (if we ever add it, for now we just match the path)
      allow get: if isOwner(userId);

      match /rulebooks/{rulebookId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        
        allow create: if isOwner(userId) 
                      && isValidId(rulebookId)
                      && isValidRulebook(incoming());
                      
        allow update: if isOwner(userId)
                      && isValidRulebook(incoming())
                      && incoming().date == resource.data.date; // Immutable date
                      
        allow delete: if isOwner(userId);
      }
    }
  }
}
