rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    function isAllowed() {
      return isAdmin() || exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));
    }

    function isOwner(userId) {
      return isAllowed() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Entity Validations ---
    function isValidRulebook(data) {
      return data.keys().hasAll(['name', 'size', 'date', 'storagePath']) && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.size is number && data.size > 0 &&
             data.date is number &&
             data.storagePath is string && data.storagePath.size() > 0;
    }

    // --- Collection Rules ---
    match /system/health {
      allow get: if true;
    }

    match /rulebooks/{rulebookId} {
      allow list: if isVerified();
      allow get: if isVerified();
      allow write: if isAdmin();

      match /chunks/{chunkId} {
        allow list, get: if isVerified();
        allow write: if isAdmin();
      }
    }

    match /allowlist/{email} {
      allow get: if isVerified() && (request.auth.token.email == email || isAdmin());
      allow write: if isAdmin();
    }
  }
}
