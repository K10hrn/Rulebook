# --- Gemini AI Configuration ---
# Get your API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# --- Admin Access ---
# The email address that has full admin rights (can upload rulebooks, manage the library).
# Other users can be granted access via the Firestore 'allowlist' collection.
VITE_ADMIN_EMAIL="your_email@example.com"

# --- Firebase Configuration ---
# Firebase credentials are stored in firebase-applet-config.json at the project root.
# To use your own Firebase project, update that file with your project's config values
# from the Firebase Console (Project Settings > Your apps > SDK setup and configuration).
